      "@board-ai-lab/hive-engine": ["packages/hive-engine/src/index.ts"],
      "@board-ai-lab/hive-play": ["packages/hive-play/src/index.ts"],
      "@board-ai-lab/hive-ga": ["packages/hive-ga/src/index.ts"],
      "@board-ai-lab/agents-random": ["packages/agents-random/src/index.ts"],
      "@board-ai-lab/agents-ga": ["packages/agents-ga/src/index.ts"],
      "@board-ai-lab/agents-llm": ["packages/agents-llm/src/index.ts"],
      "@board-ai-lab/replay-artifacts": ["packages/replay-artifacts/src/index.ts"]
    }
  }
